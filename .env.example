# ---------------------------------------------------------------------------
# 平台 API（structural-review-platform/apps/api）环境变量模板
# 复制到 structural-review-platform/apps/api/.env 后按需修改。
# ---------------------------------------------------------------------------

# 数据库（SQLite，相对 prisma 目录）
DATABASE_URL="file:./dev.db"

# 服务监听
PORT=3001
HOST=127.0.0.1

# 允许的前端来源（逗号分隔），默认本地开发端口
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# JWT 鉴权（生产环境务必设置强随机 JWT_SECRET）
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=12h

# 首次启动自动创建的默认管理员（生产请修改并尽快改密）
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_DISPLAY_NAME=系统管理员

# 上传/存储
UPLOAD_DIR=
MAX_UPLOAD_BYTES=209715200
MAX_UPLOAD_FILES=50

# 可选：图片 OCR 与 LLM（OpenAI 兼容 /chat/completions）
ENABLE_OCR=0
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
