generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  productCode String?
  description String?
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  folders     ProjectFolder[]
  jobs        ReviewJob[]
  reports     ReviewReport[]
  auditLogs   AuditLog[]
}

model ProjectFolder {
  id        String           @id @default(cuid())
  projectId String
  code      String
  name      String
  status    String           @default("未上传")
  sortOrder Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  project   Project          @relation(fields: [projectId], references: [id])
  materials MaterialObject[]
  jobs      ReviewJob[]
  reports   ReviewReport[]

  @@unique([projectId, code])
}

model MaterialObject {
  id              String         @id @default(cuid())
  projectFolderId String
  type            String
  name            String
  originalName    String?
  storagePath     String?
  sizeBytes       Int?
  mimeType        String?
  deletedAt       DateTime?
  permanentlyDeletedAt DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  folder          ProjectFolder  @relation(fields: [projectFolderId], references: [id])
  reviewLinks     ReviewMaterial[]
}

model ReviewJob {
  id              String           @id @default(cuid())
  projectId       String
  projectFolderId String?
  reviewType      String
  status          String           @default("pending")
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime         @default(now())
  project         Project          @relation(fields: [projectId], references: [id])
  folder          ProjectFolder?   @relation(fields: [projectFolderId], references: [id])
  materials       ReviewMaterial[]
  reports         ReviewReport[]
}

model ReviewMaterial {
  id               String         @id @default(cuid())
  reviewJobId      String
  materialObjectId String
  removedAt        DateTime?
  removeReason     String?
  reviewJob        ReviewJob      @relation(fields: [reviewJobId], references: [id])
  materialObject   MaterialObject @relation(fields: [materialObjectId], references: [id])

  @@unique([reviewJobId, materialObjectId])
}

model ReviewReport {
  id              String         @id @default(cuid())
  projectId       String
  projectFolderId String?
  reviewJobId     String
  baseName        String
  markdownPath    String?
  excelPath       String?
  wordPath        String?
  pdfPath         String?
  markdownContent String?
  createdAt       DateTime       @default(now())
  project         Project        @relation(fields: [projectId], references: [id])
  folder          ProjectFolder? @relation(fields: [projectFolderId], references: [id])
  reviewJob       ReviewJob      @relation(fields: [reviewJobId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  projectId  String?
  action     String
  targetType String
  targetId   String?
  message    String?
  createdAt  DateTime @default(now())
  project    Project? @relation(fields: [projectId], references: [id])
}
